class Solution {
public:
    vector<int> intersection(vector<int>& nums1, vector<int>& nums2) {//)O(n+m) Time
         unordered_set<int> set1(nums1.begin(),nums1.end());
         vector<int> result;

         for(int num:nums2){
            if(set1.count(num)>0){
                result.push_back(num);
                set1.erase(num);
            }
         }
         return result;
    }
};
