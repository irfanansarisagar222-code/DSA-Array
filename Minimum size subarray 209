class Solution {
public:
    int minSubArrayLen(int target, vector<int>& nums) {// O(n)Time
            int n=nums.size();
        int left=0;
        int currentsum=0;
        int minLength=INT_MAX;

        for(int right=0;right<n;right++){
            currentsum+=nums[right];

            while(currentsum>=target){
            minLength = min(minLength, right - left + 1);                currentsum-=nums[left];
                left++;
            }
        }
        return(minLength == INT_MAX) ? 0 : minLength;
    }
};
